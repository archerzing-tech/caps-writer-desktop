{
  "$schema": "https://raw.githubusercontent.com/nicheoid/tauri-config-schema/main/tauri-config.json",
  "productName": "CapsWriter-Desktop",
  "version": "0.3.0",
  "identifier": "com.capswriter.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx vite",
    "beforeBuildCommand": "npx vite build"
  },
  "app": {
    "windows": [
      {
        "title": "CapsWriter Desktop · 语音输入",
        "width": 800,
        "height": 660,
        "minWidth": 680,
        "minHeight": 540,
        "resizable": true,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": ["../sidecar/**/*"],
    "macOS": {
      "infoPlist": "./Info.plist"
    }
  }
}
